    {
      "parameters": {
        "jsCode": "const webhookJson = $('Webhook').first().json;\nconst body = webhookJson.body || webhookJson;\nconst action = body.action;\nconst sourceFilter = body.source || 'all';\n\nif (action !== 'get-pending') return [];\n\nconst allRows = $input.all();\n\nconst pending = allRows.filter(row => {\n  const j = row.json;\n  // New format: Progress='relevant'\n  // Legacy format (pre-migration): Status='Relevant' + Progress='new'\n  const isRelevant = j['Progress'] === 'relevant' ||\n    (j['Status'] === 'Relevant' && (j['Progress'] === 'new' || !j['Progress']));\n  if (!isRelevant) return false;\n  if (!j['Apply URL'] || !j['Apply URL'].trim()) return false;\n\n  if (sourceFilter !== 'all') {\n    const rowSource = String(j['Source'] ?? '').toLowerCase();\n    const isUsajobs = rowSource === 'usajobs';\n    if (sourceFilter === 'usajobs' && !isUsajobs) return false;\n    if (sourceFilter === 'wttj' && isUsajobs) return false;\n  }\n  return true;\n});\n\nconst jobs = pending.map(row => {\n  const j = row.json;\n  const rowSource = String(j['Source'] ?? '').toLowerCase();\n  const source = rowSource === 'usajobs' ? 'usajobs' : 'wttj';\n  return {\n    jobId: j['Job ID'] || '',\n    company: j['Company'] || '',\n    jobTitle: j['Job Title'] || '',\n    url: j['URL'] || '',\n    applyUrl: j['Apply URL'] || '',\n    location: j['Location'] || '',\n    salary: j['Salary'] || '',\n    source\n  };\n});\n\nreturn [{ json: { jobs, count: jobs.length } }];"
      },
